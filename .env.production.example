# Copy this file to .env.production and replace every placeholder.
# Use URL-safe characters because this value is embedded in DATABASE_URL.
POSTGRES_PASSWORD=replace-with-a-long-url-safe-database-password
JWT_SECRET=replace-with-at-least-32-random-characters
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-administrator-password

# Public browser origins, without paths. Separate multiple origins with commas.
CORS_ALLOWED_ORIGINS=https://fungi.example.com,https://admin.fungi.example.com

# Host ports used behind your TLS reverse proxy.
WEB_PORT=80
ADMIN_PORT=8081

# Change this only when the container network or reverse proxy range differs.
TRUSTED_PROXIES=172.16.0.0/12

# OpenAI-compatible embedding service used by semantic and hybrid search.
EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
EMBEDDING_API_KEY=replace-with-embedding-api-key
EMBEDDING_MODEL=text-embedding-3-small
